# Production Environment Variables
# Deploy these as environment variables in Coolify dashboard

# Backend URL (public HTTPS via Cloudflare Tunnel)
NEXT_PUBLIC_BACKEND_URL=https://api.timejournal.site

# NextAuth
NEXTAUTH_URL=https://timejournal.site
NEXTAUTH_SECRET=your-secret-key-here-change-this

# Google OAuth (opsional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
