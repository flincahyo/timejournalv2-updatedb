# ============================================================
# TimeJournal Environment Variables — copy to .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=timejournal
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=timejournal

DATABASE_URL=postgresql+asyncpg://timejournal:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/timejournal

# ── Auth (JWT) ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_PYTHON_SECRETS_TOKEN_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://backend:8000

# ── AI (xAI Grok) ────────────────────────────────────────────
XAI_API_KEY=your_xai_api_key_here

# ── Nginx ports ───────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── MT5 (Linux/Wine) ──────────────────────────────────────────
# Path to terminal64.exe INSIDE the container (Wine path)
# Example: C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_TERMINAL_PATH=
