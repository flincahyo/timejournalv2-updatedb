# MT5 Bridge Configuration (Push Mode)
# Copy this to .env and edit the values

# ── REQUIRED: Backend API URL ─────────────────────────────────────────────────
# Production: use your public domain
BACKEND_URL=https://api.timejournal.site

# Development: use your local backend
# BACKEND_URL=http://192.168.232.97:8000

# ── REQUIRED: Same key as backend MT5_BRIDGE_API_KEY ─────────────────────────
MT5_BRIDGE_API_KEY=X-6oT-Rda7j7XcmMX2x_Vl1Jl8W-uaFz

# ── OPTIONAL: Push interval in seconds (default: 10) ─────────────────────────
MT5_POLL_INTERVAL=10

# ── OPTIONAL: Local server config (for health check endpoint) ─────────────────
MT5_BRIDGE_HOST=127.0.0.1
MT5_BRIDGE_PORT=8765
